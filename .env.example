# Keystatic GitHub mode (production, e.g. Vercel).
# Local `npm run dev` uses local mode and does NOT need these.
#
# You get the Client ID and Secret when you create the GitHub App from the
# deployed site at /keystatic/setup (Keystatic guides you). KEYSTATIC_SECRET is
# a random string you generate yourself, e.g.  openssl rand -hex 32

KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
KEYSTATIC_SECRET=

# Optional: the GitHub App's slug, powers the "Manage app" link in the admin UI.
PUBLIC_KEYSTATIC_GITHUB_APP_SLUG=
